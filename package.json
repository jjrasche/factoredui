{
  "name": "factoredui",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:kotlin",
    "build:core": "npm run build -w @factoredui/core",
    "build:kotlin": "cd packages/kotlin-compose && ./gradlew assemble",
    "test": "vitest run",
    "test:kotlin": "cd packages/kotlin-compose && ./gradlew allTests",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "jsdom": "^26.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
