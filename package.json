{
  "name": "factoredui",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @factoredui/core && npm run build -w @factoredui/adapter-supabase && npm run build -w @factoredui/react && npm run build -w @factoredui/react-native",
    "build:core": "npm run build -w @factoredui/core",
    "build:adapter-supabase": "npm run build -w @factoredui/adapter-supabase",
    "build:react": "npm run build -w @factoredui/react",
    "build:react-native": "npm run build -w @factoredui/react-native",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "@types/react-native": "^0.72.8",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
