{
  "name": "@factoredui/core",
  "version": "0.4.0",
  "description": "Capture, factors, experiments, SDUI engine — pure TypeScript, no framework deps",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "factoredui": "./dist/cli/factoredui.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "supabase/migrations"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jimjrasche/factored-ui",
    "directory": "packages/core"
  },
  "keywords": ["analytics", "behavioral-factors", "experiments", "sdui", "supabase", "capture"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.0.0"
  }
}
