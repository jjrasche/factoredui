{
  "spec_version": 1,
  "renderer_min": 1,
  "root": {
    "id": "character",
    "type": "scrollview",
    "children": [
      {
        "id": "char-col",
        "type": "column",
        "props": { "padding": 8, "gap": 16 },
        "children": [
          { "id": "char-title", "type": "text", "props": { "value": "Character — {characterDisplayName}", "variant": "heading" } },
          {
            "id": "char-picker",
            "type": "select",
            "props": {
              "value": "{characterId}",
              "placeholder": "Pick a character",
              "options": [
                { "value": "heigl", "label": "heigl" },
                { "value": "eli", "label": "Eli" },
                { "value": "kai", "label": "Kai" },
                { "value": "mira", "label": "Mira" },
                { "value": "noa", "label": "Noa" },
                { "value": "noa_ai", "label": "noa_ai" },
                { "value": "thea", "label": "Thea" }
              ]
            }
          },
          { "id": "char-sub", "type": "text", "props": { "value": "Speak who they are — describe them out loud, pause, and watch them take shape. Confirm each gate to spend on the next.", "variant": "caption" } },
          {
            "id": "live-card",
            "type": "card",
            "children": [
              {
                "id": "live-col",
                "type": "column",
                "props": { "padding": 16, "gap": 6 },
                "children": [
                  { "id": "live-q", "type": "text", "props": { "value": "{characterQuestion}", "variant": "subheading" } },
                  { "id": "live-narr", "type": "text", "props": { "value": "{characterNarration}", "variant": "caption" } }
                ]
              }
            ]
          },
          {
            "id": "panes",
            "type": "row",
            "props": { "gap": 24 },
            "children": [
              {
                "id": "pane-appearance",
                "type": "column",
                "props": { "gap": 14, "flex": 1 },
                "children": [
                  { "id": "ap-h", "type": "text", "props": { "value": "Appearance", "variant": "subheading" } },
                  { "id": "render-slot", "type": "image", "props": { "source": "{characterImage}", "aspectRatio": 0.8, "fit": "contain", "cornerRadius": 8, "alt": "generated character render" } },
                  { "id": "render-hint", "type": "text", "props": { "value": "Identity reference now; fresh renders land here when the render leg is wired.", "variant": "caption" } },
                  { "id": "ap-desc-h", "type": "text", "props": { "value": "Look", "variant": "subheading" } },
                  { "id": "ap-desc", "type": "text", "props": { "value": "{characterAppearance}", "variant": "body" } },
                  {
                    "id": "ladder",
                    "type": "row",
                    "props": { "gap": 8 },
                    "children": [
                      { "id": "g-schema", "type": "chip", "props": { "label": "schema · locked" } },
                      { "id": "g-1view", "type": "chip", "props": { "label": "1 view · done" } },
                      { "id": "g-4views", "type": "chip", "props": { "label": "4 views · next" } },
                      { "id": "g-poses", "type": "chip", "props": { "label": "poses" } },
                      { "id": "g-mesh", "type": "chip", "props": { "label": "3D mesh" } }
                    ]
                  },
                  {
                    "id": "view-grid",
                    "type": "grid",
                    "props": { "columns": 2, "gap": 12 },
                    "children": [
                      { "id": "v-front", "type": "card", "children": [ { "id": "v-front-t", "type": "text", "props": { "value": "front", "variant": "caption" } } ] },
                      { "id": "v-right", "type": "card", "children": [ { "id": "v-right-t", "type": "text", "props": { "value": "right", "variant": "caption" } } ] },
                      { "id": "v-back", "type": "card", "children": [ { "id": "v-back-t", "type": "text", "props": { "value": "back", "variant": "caption" } } ] },
                      { "id": "v-left", "type": "card", "children": [ { "id": "v-left-t", "type": "text", "props": { "value": "left", "variant": "caption" } } ] }
                    ]
                  }
                ]
              },
              {
                "id": "pane-audition",
                "type": "column",
                "props": { "gap": 12, "flex": 1 },
                "children": [
                  { "id": "aud-h", "type": "text", "props": { "value": "Audition — tune the personality, watch it move", "variant": "subheading" } },
                  { "id": "aud-note", "type": "text", "props": { "value": "Bones-react playback lands when the audition solver ships; tune the signature here now.", "variant": "caption" } },
                  { "id": "effort-label", "type": "text", "props": { "value": "nearest effort: {characterEffort}", "variant": "subheading" } },
                  { "id": "p-weight-l", "type": "text", "props": { "value": "Laban weight (light ↔ strong)", "variant": "caption" } },
                  { "id": "p-weight", "type": "slider", "props": { "min": -1, "max": 1, "step": 0.05, "value": "{character.personality.laban_weight}" } },
                  { "id": "p-time-l", "type": "text", "props": { "value": "Laban time (sustained ↔ sudden)", "variant": "caption" } },
                  { "id": "p-time", "type": "slider", "props": { "min": -1, "max": 1, "step": 0.05, "value": "{character.personality.laban_time}" } },
                  { "id": "p-space-l", "type": "text", "props": { "value": "Laban space (indirect ↔ direct)", "variant": "caption" } },
                  { "id": "p-space", "type": "slider", "props": { "min": -1, "max": 1, "step": 0.05, "value": "{character.personality.laban_space}" } },
                  { "id": "p-flow-l", "type": "text", "props": { "value": "Laban flow (free ↔ bound)", "variant": "caption" } },
                  { "id": "p-flow", "type": "slider", "props": { "min": -1, "max": 1, "step": 0.05, "value": "{character.personality.laban_flow}" } },
                  { "id": "p-amp-l", "type": "text", "props": { "value": "Amplitude (subtle ↔ large)", "variant": "caption" } },
                  { "id": "p-amp", "type": "slider", "props": { "min": 0.4, "max": 2, "step": 0.05, "value": "{character.personality.amplitude}" } },
                  { "id": "p-supp-l", "type": "text", "props": { "value": "Suppression (expressive ↔ held)", "variant": "caption" } },
                  { "id": "p-supp", "type": "slider", "props": { "min": 0, "max": 1, "step": 0.05, "value": "{character.personality.suppression_tendency}" } },
                  { "id": "p-rec-l", "type": "text", "props": { "value": "Recovery rate (slow ↔ quick)", "variant": "caption" } },
                  { "id": "p-rec", "type": "slider", "props": { "min": 0, "max": 1, "step": 0.05, "value": "{character.personality.recovery_rate}" } },
                  { "id": "p-reg-l", "type": "text", "props": { "value": "Emotional regulation (volatile ↔ steady)", "variant": "caption" } },
                  { "id": "p-reg", "type": "slider", "props": { "min": 0, "max": 1, "step": 0.05, "value": "{character.personality.emotional_regulation}" } }
                ]
              }
            ]
          },
          {
            "id": "history-card",
            "type": "card",
            "children": [
              {
                "id": "history-col",
                "type": "column",
                "props": { "padding": 16, "gap": 8 },
                "children": [
                  { "id": "history-h", "type": "text", "props": { "value": "History & notes", "variant": "subheading" } },
                  { "id": "history-sub", "type": "text", "props": { "value": "What you've decided about this character — the running bible. Adjustments you make to the signature are logged as training rows; they will surface here.", "variant": "caption" } },
                  { "id": "history-notes", "type": "textinput", "props": { "value": "{characterNotes}", "placeholder": "Notes & history for this character…", "multiline": true } }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
