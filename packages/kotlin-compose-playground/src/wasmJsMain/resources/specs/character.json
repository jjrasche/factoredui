{
  "spec_version": 1,
  "renderer_min": 1,
  "root": {
    "id": "character",
    "type": "column",
    "props": { "padding": 8, "gap": 10 },
    "children": [
      {
        "id": "head-row",
        "type": "row",
        "props": { "gap": 12 },
        "children": [
          { "id": "char-title", "type": "text", "props": { "value": "Character — {characterDisplayName}", "variant": "heading" } },
          {
            "id": "char-picker",
            "type": "select",
            "props": {
              "value": "{characterId}",
              "placeholder": "Pick a character",
              "options": [
                { "value": "grandfather", "label": "grandfather" },
                { "value": "heigl", "label": "heigl" },
                { "value": "eli", "label": "Eli" },
                { "value": "kai", "label": "Kai" },
                { "value": "mira", "label": "Mira" },
                { "value": "noa", "label": "Noa" },
                { "value": "noa_ai", "label": "noa_ai" },
                { "value": "thea", "label": "Thea" }
              ]
            }
          }
        ]
      },
      { "id": "live-q", "type": "text", "props": { "value": "{characterQuestion}", "variant": "subheading" } },
      { "id": "live-narr", "type": "text", "props": { "value": "{characterNarration}", "variant": "caption" } },
      { "id": "create-status", "type": "text", "props": { "value": "{createStatus}", "variant": "caption" } },
      {
        "id": "dash",
        "type": "row",
        "props": { "gap": 16 },
        "children": [
          {
            "id": "dash-identity",
            "type": "column",
            "props": { "gap": 6 },
            "children": [
              { "id": "id-img", "type": "image", "props": { "source": "{characterImage}", "aspectRatio": 0.8, "maxHeight": 300, "fit": "contain", "cornerRadius": 8, "alt": "character headshot" } },
              { "id": "id-status", "type": "text", "props": { "value": "{renderStatus}", "variant": "caption" } },
              { "id": "id-refstatus", "type": "text", "props": { "value": "{referenceUploadStatus}", "variant": "caption" } },
              { "id": "id-look", "type": "text", "props": { "value": "{characterRenderPrompt}", "variant": "caption" } }
            ]
          },
          {
            "id": "dash-look",
            "type": "column",
            "props": { "gap": 4, "flex": 1 },
            "children": [
              { "id": "look-h", "type": "text", "props": { "value": "Look", "variant": "subheading" } },
              { "id": "look-desc", "type": "text", "props": { "value": "{characterAppearance}", "variant": "caption" } },
              {
                "id": "look-grid",
                "type": "grid",
                "props": { "columns": 2, "gap": 4 },
                "children": [
                  { "id": "la-age", "type": "text", "props": { "value": "Age · {characterAttr.apparent_age}", "variant": "caption" } },
                  { "id": "la-build", "type": "text", "props": { "value": "Build · {characterAttr.build}", "variant": "caption" } },
                  { "id": "la-height", "type": "text", "props": { "value": "Height · {characterAttr.height_impression}", "variant": "caption" } },
                  { "id": "la-cond", "type": "text", "props": { "value": "Condition · {characterAttr.physical_condition}", "variant": "caption" } },
                  { "id": "la-hair", "type": "text", "props": { "value": "Hair · {characterAttr.hair}", "variant": "caption" } },
                  { "id": "la-skin", "type": "text", "props": { "value": "Skin · {characterAttr.skin}", "variant": "caption" } },
                  { "id": "la-eyes", "type": "text", "props": { "value": "Eyes · {characterAttr.eyes}", "variant": "caption" } },
                  { "id": "la-feat", "type": "text", "props": { "value": "Features · {characterAttr.distinguishing_features}", "variant": "caption" } },
                  { "id": "la-acc", "type": "text", "props": { "value": "Accessories · {characterAttr.accessories}", "variant": "caption" } },
                  { "id": "la-ward", "type": "text", "props": { "value": "Wardrobe · {characterAttr.wardrobe}", "variant": "caption" } },
                  { "id": "la-groom", "type": "text", "props": { "value": "Grooming · {characterAttr.grooming}", "variant": "caption" } },
                  { "id": "la-posture", "type": "text", "props": { "value": "Posture · {characterAttr.posture}", "variant": "caption" } },
                  { "id": "la-gait", "type": "text", "props": { "value": "Gait · {characterAttr.gait}", "variant": "caption" } },
                  { "id": "la-demeanor", "type": "text", "props": { "value": "Demeanor · {characterAttr.demeanor}", "variant": "caption" } },
                  { "id": "la-affect", "type": "text", "props": { "value": "Affect · {characterAttr.baseline_affect}", "variant": "caption" } },
                  { "id": "la-palette", "type": "text", "props": { "value": "Palette · {characterAttr.palette}", "variant": "caption" } },
                  { "id": "la-era", "type": "text", "props": { "value": "Era · {characterAttr.era}", "variant": "caption" } }
                ]
              }
            ]
          },
          {
            "id": "dash-sig",
            "type": "column",
            "props": { "gap": 2, "flex": 1 },
            "children": [
              { "id": "sig-h", "type": "text", "props": { "value": "Signature · effort: {characterEffort}", "variant": "subheading" } },
              {
                "id": "sig-grid",
                "type": "grid",
                "props": { "columns": 2, "gap": 6 },
                "children": [
                  {
                    "id": "sg-weight", "type": "column", "props": { "gap": 0 }, "children": [
                      { "id": "sg-weight-l", "type": "text", "props": { "value": "weight (light↔strong)", "variant": "caption" } },
                      { "id": "p-weight", "type": "slider", "props": { "min": -1, "max": 1, "step": 0.05, "value": "{character.personality.laban_weight}" }, "action": { "action": "persist-dial", "params": { "field": "laban_weight", "value": "{character.personality.laban_weight}", "character_id": "{characterId}" } } }
                    ]
                  },
                  {
                    "id": "sg-time", "type": "column", "props": { "gap": 0 }, "children": [
                      { "id": "sg-time-l", "type": "text", "props": { "value": "time (sustained↔sudden)", "variant": "caption" } },
                      { "id": "p-time", "type": "slider", "props": { "min": -1, "max": 1, "step": 0.05, "value": "{character.personality.laban_time}" }, "action": { "action": "persist-dial", "params": { "field": "laban_time", "value": "{character.personality.laban_time}", "character_id": "{characterId}" } } }
                    ]
                  },
                  {
                    "id": "sg-space", "type": "column", "props": { "gap": 0 }, "children": [
                      { "id": "sg-space-l", "type": "text", "props": { "value": "space (indirect↔direct)", "variant": "caption" } },
                      { "id": "p-space", "type": "slider", "props": { "min": -1, "max": 1, "step": 0.05, "value": "{character.personality.laban_space}" }, "action": { "action": "persist-dial", "params": { "field": "laban_space", "value": "{character.personality.laban_space}", "character_id": "{characterId}" } } }
                    ]
                  },
                  {
                    "id": "sg-flow", "type": "column", "props": { "gap": 0 }, "children": [
                      { "id": "sg-flow-l", "type": "text", "props": { "value": "flow (free↔bound)", "variant": "caption" } },
                      { "id": "p-flow", "type": "slider", "props": { "min": -1, "max": 1, "step": 0.05, "value": "{character.personality.laban_flow}" }, "action": { "action": "persist-dial", "params": { "field": "laban_flow", "value": "{character.personality.laban_flow}", "character_id": "{characterId}" } } }
                    ]
                  },
                  {
                    "id": "sg-amp", "type": "column", "props": { "gap": 0 }, "children": [
                      { "id": "sg-amp-l", "type": "text", "props": { "value": "amplitude", "variant": "caption" } },
                      { "id": "p-amp", "type": "slider", "props": { "min": 0.4, "max": 2, "step": 0.05, "value": "{character.personality.amplitude}" }, "action": { "action": "persist-dial", "params": { "field": "amplitude", "value": "{character.personality.amplitude}", "character_id": "{characterId}" } } }
                    ]
                  },
                  {
                    "id": "sg-supp", "type": "column", "props": { "gap": 0 }, "children": [
                      { "id": "sg-supp-l", "type": "text", "props": { "value": "suppression", "variant": "caption" } },
                      { "id": "p-supp", "type": "slider", "props": { "min": 0, "max": 1, "step": 0.05, "value": "{character.personality.suppression_tendency}" }, "action": { "action": "persist-dial", "params": { "field": "suppression_tendency", "value": "{character.personality.suppression_tendency}", "character_id": "{characterId}" } } }
                    ]
                  },
                  {
                    "id": "sg-rec", "type": "column", "props": { "gap": 0 }, "children": [
                      { "id": "sg-rec-l", "type": "text", "props": { "value": "recovery", "variant": "caption" } },
                      { "id": "p-rec", "type": "slider", "props": { "min": 0, "max": 1, "step": 0.05, "value": "{character.personality.recovery_rate}" }, "action": { "action": "persist-dial", "params": { "field": "recovery_rate", "value": "{character.personality.recovery_rate}", "character_id": "{characterId}" } } }
                    ]
                  },
                  {
                    "id": "sg-reg", "type": "column", "props": { "gap": 0 }, "children": [
                      { "id": "sg-reg-l", "type": "text", "props": { "value": "regulation", "variant": "caption" } },
                      { "id": "p-reg", "type": "slider", "props": { "min": 0, "max": 1, "step": 0.05, "value": "{character.personality.emotional_regulation}" }, "action": { "action": "persist-dial", "params": { "field": "emotional_regulation", "value": "{character.personality.emotional_regulation}", "character_id": "{characterId}" } } }
                    ]
                  }
                ]
              },
              { "id": "regen-toggle", "type": "toggle", "props": { "label": "Auto-regenerate image as I speak", "value": "{autoRegenerate}" } }
            ]
          }
        ]
      }
    ]
  }
}
