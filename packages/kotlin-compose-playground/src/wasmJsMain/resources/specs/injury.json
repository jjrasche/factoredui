{
  "spec_version": 1,
  "renderer_min": 1,
  "root": {
    "id": "injury",
    "type": "column",
    "props": { "gap": 4, "padding": 4 },
    "children": [
      { "id": "inj-title", "type": "text", "props": { "value": "Injury — drag the severity, pick the hurt leg, watch it favor (LIVE engine)", "variant": "heading" } },
      { "id": "inj-sub", "type": "text", "props": { "value": "Live motion engine on :8765. PLAY/PAUSE the hop, SCRUB the timeline (drag back to reverse). Crank SEVERITY 0→1: healthy alternating hop → favoring the good leg, hurt leg glows. Switch the INJURED LIMB to flip sides. Each change re-solves in ~3ms.", "variant": "caption" } },
      { "id": "inj-scene", "type": "scene3d", "props": { "engine_url": "http://127.0.0.1:8765/engine/solve", "engine": "{injury.engine}", "board": "hopscotch", "impulse": "{injury.impulse}", "severity": "{injury.severity}", "effector": "{injury.endEffector}", "background": "neutral-gray", "flex": 1 } },
      {
        "id": "inj-controls",
        "type": "row",
        "props": { "gap": 16 },
        "children": [
          {
            "id": "inj-engine-col",
            "type": "column",
            "props": { "gap": 0, "flex": 1 },
            "children": [
              { "id": "inj-engine-l", "type": "text", "props": { "value": "motion engine", "variant": "caption" } },
              {
                "id": "inj-engine",
                "type": "select",
                "props": {
                  "value": "{injury.engine}",
                  "options": [
                    { "value": "injury", "label": "injury optimizer (ground truth · slow)" },
                    { "value": "fastgen", "label": "fastgen distill (fast)" },
                    { "value": "embodiment-tracked", "label": "harness: TRACKED loop (motion-gen + tracker + physics — force knocks it, it recovers)" },
                    { "value": "embodiment-kinematic", "label": "harness: KINEMATIC loop (motion-gen only — force does nothing)" }
                  ]
                }
              }
            ]
          },
          {
            "id": "inj-severity-col",
            "type": "column",
            "props": { "gap": 0, "flex": 1 },
            "children": [
              { "id": "inj-severity-l", "type": "text", "props": { "value": "severity — healthy ↔ badly hurt", "variant": "caption" } },
              { "id": "inj-severity", "type": "slider", "props": { "min": 0, "max": 1, "step": 0.05, "value": "{injury.severity}" } }
            ]
          },
          {
            "id": "inj-effector-col",
            "type": "column",
            "props": { "gap": 0, "flex": 1 },
            "children": [
              { "id": "inj-effector-l", "type": "text", "props": { "value": "injured limb", "variant": "caption" } },
              {
                "id": "inj-effector",
                "type": "select",
                "props": {
                  "value": "{injury.endEffector}",
                  "options": [
                    { "value": "R_leg", "label": "right leg" },
                    { "value": "L_leg", "label": "left leg" },
                    { "value": "R_arm", "label": "right arm" },
                    { "value": "L_arm", "label": "left arm" }
                  ]
                }
              }
            ]
          },
          {
            "id": "inj-impulse-col",
            "type": "column",
            "props": { "gap": 0, "flex": 1 },
            "children": [
              { "id": "inj-impulse-l", "type": "text", "props": { "value": "impulse — how hard the hit lands", "variant": "caption" } },
              { "id": "inj-impulse", "type": "slider", "props": { "min": 0, "max": 1, "step": 0.05, "value": "{injury.impulse}" } }
            ]
          }
        ]
      }
    ]
  }
}
