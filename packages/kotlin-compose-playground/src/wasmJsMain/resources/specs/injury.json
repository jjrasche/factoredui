{
  "spec_version": 1,
  "renderer_min": 1,
  "root": {
    "id": "injury",
    "type": "column",
    "props": { "gap": 4, "padding": 4 },
    "children": [
      { "id": "inj-title", "type": "text", "props": { "value": "Injury — set the hit, the target, and the severity; watch it reach guarding", "variant": "heading" } },
      { "id": "inj-sub", "type": "text", "props": { "value": "Drag the GREEN target → the body reaches it (pick which limb). Crank SEVERITY → the reach goes slow, stuttering, hunched — guarded. Drag the RED ball to place the hit → pain blooms there. The reach loops so you can watch it. (Client-side port of il-injury's guard transform — the offline optimizer is the ground truth it's tuned against.)", "variant": "caption" } },
      { "id": "inj-scene", "type": "scene3d", "props": { "clip_url": "clips/injury_scene_stream.json", "impulse": "{injury.impulse}", "severity": "{injury.severity}", "effector": "{injury.endEffector}", "background": "neutral-gray", "flex": 1 } },
      {
        "id": "inj-controls",
        "type": "row",
        "props": { "gap": 16 },
        "children": [
          {
            "id": "inj-severity-col",
            "type": "column",
            "props": { "gap": 0, "flex": 1 },
            "children": [
              { "id": "inj-severity-l", "type": "text", "props": { "value": "severity — healthy ↔ badly hurt", "variant": "caption" } },
              { "id": "inj-severity", "type": "slider", "props": { "min": 0, "max": 1, "step": 0.05, "value": "{injury.severity}" } }
            ]
          },
          {
            "id": "inj-effector-col",
            "type": "column",
            "props": { "gap": 0, "flex": 1 },
            "children": [
              { "id": "inj-effector-l", "type": "text", "props": { "value": "reach with", "variant": "caption" } },
              {
                "id": "inj-effector",
                "type": "select",
                "props": {
                  "value": "{injury.endEffector}",
                  "options": [
                    { "value": "R_Hand", "label": "right hand" },
                    { "value": "L_Hand", "label": "left hand" },
                    { "value": "R_Foot", "label": "right foot" },
                    { "value": "L_Foot", "label": "left foot" }
                  ]
                }
              }
            ]
          },
          {
            "id": "inj-impulse-col",
            "type": "column",
            "props": { "gap": 0, "flex": 1 },
            "children": [
              { "id": "inj-impulse-l", "type": "text", "props": { "value": "impulse — how hard the hit lands", "variant": "caption" } },
              { "id": "inj-impulse", "type": "slider", "props": { "min": 0, "max": 1, "step": 0.05, "value": "{injury.impulse}" } }
            ]
          }
        ]
      }
    ]
  }
}
