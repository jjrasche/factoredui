{
  "spec_version": 1,
  "renderer_min": 1,
  "root": {
    "id": "fieldgraph-demo",
    "type": "column",
    "props": { "flex": 1 },
    "children": [
      {
        "id": "fg-header",
        "type": "row",
        "props": { "padding": 12, "gap": 8 },
        "children": [
          {
            "id": "fg-title",
            "type": "text",
            "props": { "value": "Scene Focus", "variant": "heading" }
          },
          {
            "id": "fg-hint",
            "type": "text",
            "props": { "value": "drag what matters inward — updates injury simulation live", "variant": "caption" }
          }
        ]
      },
      {
        "id": "fg-field",
        "type": "fieldgraph",
        "props": {
          "topology_url": "topology/scene-focus.json",
          "on_relevance_change": "on-focus-change"
        }
      },
      {
        "id": "fg-status",
        "type": "row",
        "props": { "padding": 12, "gap": 24 },
        "children": [
          {
            "id": "fg-sev-col",
            "type": "column",
            "props": { "gap": 2 },
            "children": [
              { "id": "fg-sev-l", "type": "text", "props": { "value": "injury.severity", "variant": "caption" } },
              { "id": "fg-sev",   "type": "slider", "props": { "min": 0, "max": 1, "step": 0.01, "value": "{injury.severity}" } }
            ]
          },
          {
            "id": "fg-imp-col",
            "type": "column",
            "props": { "gap": 2 },
            "children": [
              { "id": "fg-imp-l", "type": "text", "props": { "value": "injury.impulse", "variant": "caption" } },
              { "id": "fg-imp",   "type": "slider", "props": { "min": 0, "max": 1, "step": 0.01, "value": "{injury.impulse}" } }
            ]
          },
          {
            "id": "fg-legend-col",
            "type": "column",
            "props": { "gap": 4 },
            "children": [
              { "id": "fg-legend-entity", "type": "chip", "props": { "label": "○ entity" } },
              { "id": "fg-legend-claim",  "type": "chip", "props": { "label": "● claim" } }
            ]
          }
        ]
      }
    ]
  }
}
