{
  "name": "@factoredui/react-native",
  "version": "0.5.2",
  "description": "React Native component registry for FactoredUI SDUI — 20 themed primitives",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jjrasche/factoredui",
    "directory": "packages/react-native"
  },
  "keywords": [
    "react-native",
    "expo",
    "sdui",
    "component-registry",
    "supabase"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@factoredui/core": "^0.5.0",
    "@factoredui/react": "^0.5.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-native": ">=0.73.0"
  }
}
