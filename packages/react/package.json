{
  "name": "@factoredui/react",
  "version": "0.4.0",
  "description": "React bindings for FactoredUI — provider, hooks, path context, SDUI renderer",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jimjrasche/factored-ui",
    "directory": "packages/react"
  },
  "keywords": ["react", "hooks", "behavioral-factors", "experiments", "sdui", "supabase"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@factoredui/core": "^0.2.0",
    "@supabase/supabase-js": "^2.0.0",
    "react": "^18.0.0 || ^19.0.0"
  }
}
