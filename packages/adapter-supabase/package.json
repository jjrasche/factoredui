{
  "name": "@factoredui/adapter-supabase",
  "version": "0.5.0",
  "description": "Supabase adapter for FactoredUI — persistence, migrations, CLI, edge functions",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "factoredui": "./dist/cli/factoredui.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "supabase/migrations",
    "supabase/functions",
    "supabase/config.toml"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jjrasche/factoredui",
    "directory": "packages/adapter-supabase"
  },
  "keywords": [
    "supabase",
    "adapter",
    "factoredui",
    "behavioral-factors",
    "experiments",
    "migrations"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@factoredui/core": "^0.5.0",
    "@supabase/supabase-js": "^2.0.0"
  }
}
